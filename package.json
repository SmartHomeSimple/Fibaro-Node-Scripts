    "url": "https://github.com/SmartHomeSimple/Fibaro-Node-Scripts/issues"
  },
  "homepage": "https://github.com/SmartHomeSimple/Fibaro-Node-Scripts/tree/main",
  "engines": {
    "node": ">=14.0.0"
  }
